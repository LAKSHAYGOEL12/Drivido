# Copy to `.env`. Backend URL: change ONLY the line below (see src/config/apiBaseUrl.ts).
# Origin only — no /api, no trailing slash. Then: npx expo start --clear
EXPO_PUBLIC_API_URL=https://drivido-fzh4i.ondigitalocean.app

# Expo push token (dev build / APK — not Expo Go). Project ID: expo.dev → your project → Project settings,
# or run: npx eas project:info   (requires eas login + eas init)
# EXPO_PUBLIC_EAS_PROJECT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Google Maps — same key variable the app uses for Maps + Geocoding + Places
EXPO_PUBLIC_GOOGLE_MAPS_ANDROID_KEY=your_android_maps_key_here
# EXPO_PUBLIC_GOOGLE_MAPS_IOS_KEY=your_ios_maps_key_here

# Firebase (required for app auth). Console → Project settings → Your apps → Web app config
# EXPO_PUBLIC_FIREBASE_API_KEY=
# EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
# EXPO_PUBLIC_FIREBASE_PROJECT_ID=
# EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
# EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# EXPO_PUBLIC_FIREBASE_APP_ID=
#
# Firestore: enable in Console; rules so each user can read/write `users/{uid}`.
#
