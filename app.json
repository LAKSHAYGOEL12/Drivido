{
  "expo": {
    "name": "EcoPickO",
    "slug": "ecopicko",
    "scheme": "ecopicko",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/app-logo.png",
    "userInterfaceStyle": "light",
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-native-blank.png",
          "backgroundColor": "#ffffff",
          "resizeMode": "contain"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/app-logo.png",
          "color": "#1DB954",
          "defaultChannel": "default",
          "sounds": [],
          "enableBackgroundRemoteNotifications": true
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "EcoPickO uses your location while the app is open to suggest nearby pickups and improve route accuracy."
        }
      ],
      [
        "react-native-maps",
        {
          "iosGoogleMapsApiKey": "YOUR_GOOGLE_MAPS_IOS_KEY",
          "androidGoogleMapsApiKey": "YOUR_GOOGLE_MAPS_ANDROID_KEY"
        }
      ]
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "softwareKeyboardLayoutMode": "resize",
      "statusBar": {
        "backgroundColor": "#ffffff",
        "barStyle": "dark-content"
      },
      "adaptiveIcon": {
        "backgroundColor": "#E6F9EE",
        "foregroundImage": "./assets/app-logo.png"
      }
    },
    "web": {
      "favicon": "./assets/app-logo.png"
    }
  }
}
